NODE_ENV=development

# 클라이언트에서 접근 가능한 공개 변수는 NEXT_PUBLIC_ 접두사 사용
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Notion API 설정
# ============================================================

# Notion Integration 토큰 (https://www.notion.so/my-integrations 에서 발급)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 블로그 포스트가 저장된 Notion 데이터베이스 ID
# 데이터베이스 URL: https://www.notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# On-demand Revalidation 설정
# ============================================================

# 캐시 갱신 API 시크릿 토큰
# 사용법: GET /api/revalidate?secret=이값&tag=notion-posts-list
# Notion 글 발행 후 수동 또는 Webhook으로 호출하면 5분 대기 없이 즉시 갱신됩니다.
REVALIDATE_SECRET=your-secret-token-here
